{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-context7"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-playwright"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-chrome-devtools"
            ]
        },
        "serena": {
            "command": "uvx",
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server"
            ],
            "env": {
                "SERENA_PROJECT_ROOT": "${workspaceFolder}"
            }
        }
    }
}